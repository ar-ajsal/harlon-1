nish.\u003c\/li\u003e\n\u003c\/ul\u003e\n\n\u003ch4\u003eCore Features\u003c\/h4\u003e\n\u003cul\u003e\n\u003cli\u003e420 GSM taped fleece construction for a substantial premium feel.\u003c\/li\u003e\n\u003cli\u003eStraight baggy fit designed for comfort and versatile styling.\u003c\/li\u003e\n\u003cli\u003eUnisex silhouette suited for multiple body types.\u003c\/li\u003e\n\u003cli\u003eBlank minimal design for effortless outfit pairing.\u003c\/li\u003e\n\u003cli\u003eElasticated waist for adjustable comfort and everyday wear.\u003c\/li\u003e\n\u003cli\u003eBalanced fabric weight ideal for all-season use.\u003c\/li\u003e\n\u003c\/ul\u003e","brand":"DRIP STUDIOS","offers":[{"title":"S","offer_id":46885165072538,"sku":"Reign4","price":1899.0,"currency_code":"INR","in_stock":false},{"title":"M","offer_id":46885165105306,"sku":"Reign4","price":1899.0,"currency_code":"INR","in_stock":true},{"title":"L","offer_id":46885165138074,"sku":"Reign4","price":1899.0,"currency_code":"INR","in_stock":true},{"title":"XS","offer_id":46885165170842,"sku":"Reign4","price":1899.0,"currency_code":"INR","in_stock":false},{"title":"XL","offer_id":46885165203610,"sku":"Reign4","price":1899.0,"currency_code":"INR","in_stock":true},{"title":"XXL","offer_id":46885165236378,"sku":"Reign4","price":1899.0,"currency_code":"INR","in_stock":true}],"thumbnail_url":"\/\/cdn.shopify.com\/s\/files\/1\/0717\/2584\/2586\/files\/DSC00452copy_11zon.jpg?v=1772290145"},{"product_id":"luxe-bottoms-melange-grey","title":"LUXE BOTTOMS - MELANGE GREY","description":"\u003cp\u003e MODEL HEIGHT 5'10 AND WAIST SIZE 32 WEARING M BOTTOMS.\u003cbr\u003e\u003cbr\u003e 420 GSM SOFT FLEECE LINING\u003cbr\u003e COMBED \u0026amp; BIO-WASHED FINISH\u003cbr\u003e PREMIUM 100% COTTON MATERIAL\u003cbr\u003e BAGGY FIT\u003cbr\u003e EMBROIDERED LOGO ON BACK POCKET\u003cbr\u003e BELT LOOP FOR KEYS OR LIGHTER\u003cbr\u003e ZIPPER POCKETS FOR SECURE STORAGE\u003cbr\u003e UNISEX ARTICLE [REFER TO SIZE CHART FOR ACCURATE MEASUREMENTS]