\/li\u003e\n\u003c\/ul\u003e\n\n\u003ch4\u003eCare Guide\u003c\/h4\u003e\n\u003cul\u003e\n\u003cli\u003eMachine wash the bottoms inside out with similar colors.\u003c\/li\u003e\n\u003cli\u003eUse cold water to maintain fabric texture and color richness.\u003c\/li\u003e\n\u003cli\u003eTumble dry on low heat or air dry to preserve shape.\u003c\/li\u003e\n\u003cli\u003eStore folded in a cool, dry place to retain structure and finish.\u003c\/li\u003e\n\u003c\/ul\u003e\n\n\u003ch4\u003eCore Features\u003c\/h4\u003e\n\u003cul\u003e\n\u003cli\u003e420 GSM taped fleece for a dense, premium feel.\u003c\/li\u003e\n\u003cli\u003eStraight baggy fit for versatile comfort and styling.\u003c\/li\u003e\n\u003cli\u003eUnisex silhouette suited for a wide range of body types.\u003c\/li\u003e\n\u003cli\u003eMinimal blank aesthetic for easy outfit pairing.\u003c\/li\u003e\n\u003cli\u003eElasticated waist for adjustable everyday comfort.\u003c\/li\u003e\n\u003cli\u003eBalanced fabric weight suitable for year-round wear.\u003c\/li\u003e\n\u003c\/ul\u003e","brand":"DRIP STUDIOS","offers":[{"title":"S","offer_id":46885005590682,"sku":"DS SIGNATURE SWEATPANTS","price":1799.0,"currency_code":"INR","in_stock":true},{"title":"M","offer_id":46885005623450,"sku":"DS SIGNATURE SWEATPANTS","price":1799.0,"currency_code":"INR","in_stock":true},{"title":"L","offer_id":46885005656218,"sku":"DS SIGNATURE SWEATPANTS","price":1799.0,"currency_code":"INR","in_stock":true},{"title":"XL","offer_id":46885005688986,"sku":"DS SIGNATURE SWEATPANTS","price":1799.0,"currency_code":"INR","in_stock":true},{"title":"XXL","offer_id":46885005721754,"sku":"DS SIGNATURE SWEATPANTS","price":1799.0,"currency_code":"INR","in_stock":true},{"title":"XS","offer_id":46885005754522,"sku":"DS SIGNATURE SWEATPANTS","price":1799.0,"currency_code":"INR","in_stock":true}],"thumbnail_url":"\/\/cdn.shopify.com\/s\/files\/1\/0717\/2584\/2586\/files\/IMG_5631_11zon_1.webp?v=1772291602"},{"product_id":"grey-basic-bottoms","title":"GREY B