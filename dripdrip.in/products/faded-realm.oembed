yle preferences.\u003c\/li\u003e\n  \u003cli\u003eFront pouch pocket for convenient storage and added warmth.\u003c\/li\u003e\n  \u003cli\u003eSoft, breathable jersey fabric ensures comfort and airflow.\u003c\/li\u003e\n  \u003cli\u003eLong sleeves and ribbed cuffs and hem provide a snug and stylish fit.\u003c\/li\u003e\n\u003c\/ul\u003e\n","brand":"dripdrip.dopedesk","offers":[{"title":"S","offer_id":46939960606874,"sku":null,"price":2399.0,"currency_code":"INR","in_stock":true},{"title":"M","offer_id":46939960639642,"sku":null,"price":2399.0,"currency_code":"INR","in_stock":true},{"title":"L","offer_id":46939960672410,"sku":null,"price":2399.0,"currency_code":"INR","in_stock":true},{"title":"XL","offer_id":46939960705178,"sku":null,"price":2399.0,"currency_code":"INR","in_stock":true},{"title":"2XL","offer_id":46939960737946,"sku":null,"price":2399.0,"currency_code":"INR","in_stock":true}],"thumbnail_url":"\/\/cdn.shopify.com\/s\/files\/1\/0717\/2584\/2586\/files\/D10E628D-8DF1-4DB1-A743-922425FAE790.png?v=1769971287","url":"https:\/\/dripdrip.in\/products\/faded-realm","provider":"DRIP STUDIOS","version":"1.0","type":"link"}